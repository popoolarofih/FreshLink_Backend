# ─────────────────────────────────────────────────────────────────────────────
# FreshLink Backend – Environment Variables
# Copy this file to .env and fill in real values.
#
# REQUIRED TO BOOT  = the server will not start without these
# OPTIONAL          = has a safe default or is a stub/TODO
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# REQUIRED TO BOOT
PORT=3001
NODE_ENV=development   # development | production | test

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# REQUIRED TO BOOT
# Local format: postgresql://<user>:<password>@localhost:5432/<dbname>?schema=public
# Example:      postgresql://postgres:secret@localhost:5432/freshlink?schema=public
DATABASE_URL=postgresql://postgres:secret@localhost:5432/freshlink?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
# REQUIRED TO BOOT  (used for caching, sessions, and BullMQ queues)
# Format: redis://<user>:<password>@<host>:<port>
# No-auth local:  redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Separate Redis URL for BullMQ if you want queue traffic on a different instance.
# OPTIONAL – falls back to REDIS_URL if not set.
BULL_REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED TO BOOT  – use long random strings in production (openssl rand -hex 64)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m         # e.g. 15m | 1h | 24h

JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRY=7d         # e.g. 7d | 30d

# ── Stripe ────────────────────────────────────────────────────────────────────
# REQUIRED for payment endpoints to function.
# Use Stripe test keys (sk_test_...) for local dev – safe dummy value shown.
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_TEST_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET

# ── Flutterwave (TODO – not wired up yet) ────────────────────────────────────
# OPTIONAL – leave as dummy for now, the PaymentProvider interface is stubbed.
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-REPLACE_WHEN_READY

# ── Groq LLM Integration ─────────────────────────────────────────────────────
# REQUIRED for AI-assisted features (search parsing, matchmaking, pricing,
# contracts). If GROQ_API_KEY is absent or Groq is unreachable, all services
# automatically fall back to rule-based logic — safe to leave as dummy for
# local dev without an internet connection.
#
# Get your key at: https://console.groq.com
# NEVER commit the real key — add it to your local .env only.
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_API_KEY

# Model aliases — change without redeploying to swap to newer Llama versions.
GROQ_MODEL_FAST=llama-3.1-8b-instant          # latency-sensitive: search parsing
GROQ_MODEL_REASONING=llama-3.3-70b-versatile  # quality-critical: contracts, pricing

GROQ_TIMEOUT_MS=10000     # ms before a single Groq call is aborted
GROQ_MAX_RETRIES=3        # attempts (with exponential backoff) before fallback

# ── REMOVED variables (no longer used — delete from your .env) ───────────────
# AI_SERVICE_URL      → eliminated: Groq is now called in-process, no HTTP hop
# AI_SERVICE_API_KEY  → eliminated
# AI_SERVICE_TIMEOUT_MS → replaced by GROQ_TIMEOUT_MS

# ── Email (stub) ──────────────────────────────────────────────────────────────
# OPTIONAL – email sending is stubbed (console.log) until a real provider is wired.
MAIL_FROM=noreply@freshlink.app
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── App URL (used in email verification links) ───────────────────────────────
# OPTIONAL – safe dummy for local dev
APP_BASE_URL=http://localhost:3001

# ── Rate limiting ─────────────────────────────────────────────────────────────
# OPTIONAL
THROTTLE_TTL=60000   # window in ms
THROTTLE_LIMIT=100   # max requests per window per IP
